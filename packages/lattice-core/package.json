{
  "name": "@exodus/lattice-core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Shared 2D lattice rendering primitives — PixiJS canvas, dock UI, coordinate transforms, chain-adapter contract. Consumed by apps/game (zkagenticnetwork) and apps/timegrid (Bitcoin wallet civilization viewer).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme/globals.css": "./src/theme/globals.css"
  },
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "pixi.js": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
