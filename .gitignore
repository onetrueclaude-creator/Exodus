# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# local dev artifacts
debug.log
dev.db

# Compaction memory (local only — never commit)
compacted.md
compacted-summary.md
prompts.md

# Git worktrees
.worktrees/

# Playwright
playwright-report/
test-results/

# External project trees (legacy codebases, not part of this repo)
ZkAgentic/
apps/
vault/agentic-chain/

# pnpm workspace lock (managed at monorepo root)
pnpm-lock.yaml

# Claude dispatch state (session-local, not committed)
.claude/dispatch-state.json

# Node modules anywhere in tree
**/node_modules/
