{
  "name": "exodus",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "cd apps/game && npm run dev",
    "build": "cd apps/game && npm run build",
    "test": "cd apps/game && npm test",
    "test:run": "cd apps/game && npm run test:run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:watch": "playwright test --watch",
    "test:e2e:beta": "playwright test 05-beta-testers --workers=4",
    "test:chain": "cd chain && python3 -m pytest tests/ -v",
    "lint": "cd apps/game && npm run lint"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
