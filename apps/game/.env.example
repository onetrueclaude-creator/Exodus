# Copy to .env and fill in. Do NOT commit .env (it is gitignored).

# --- Database (local dev: `docker compose up -d`, or `brew install postgresql@16`) ---
DATABASE_URL=postgresql://zkagentic:devpass@localhost:5432/zkagentic

# --- NextAuth v5 (Google OAuth) ---
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=

# --- Agentic Chain testnet API (FastAPI) ---
NEXT_PUBLIC_TESTNET_API=http://localhost:8080

# --- Identity & tier security (sub-project B) ---
# Founder role allowlist (comma-separated Google emails). Server-only; never client.
FOUNDER_EMAILS=
# Dev-only: allow the localStorage identity fallback when there is no session.
# Set to 1 for local playtests without Google login; leave unset/0 in production.
NEXT_PUBLIC_DEV_IDENTITY=
