# Build context = apps/game. Keep it lean & deterministic.
# We DO copy package.json + package-lock.json (needed for `npm ci`) and prisma/.
# We do NOT copy host build artifacts — they're regenerated inside the image so
# the build can't be poisoned by stale local state (esp. .next/standalone and the
# generated Prisma client, which must be produced fresh against the image's deps).

# Dependencies & build output (rebuilt in-image)
node_modules
.next
out
dist
src/generated/prisma

# Docker / CI meta
Dockerfile
.dockerignore
fly.toml
.git
.gitignore
.github

# Local env & secrets — NEVER ship into the image (secrets come via `fly secrets`)
.env
.env.*
!.env.example

# Tests & tooling not needed at runtime
**/__tests__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
vitest.config.*
vitest.setup.*
playwright.config.*
scripts/visual-debug

# Editor / OS cruft
.DS_Store
*.log
npm-debug.log*
coverage
.vscode
.idea

# Docs (not needed in the runtime image)
CLAUDE.md
README.md
seed.md
