generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- NextAuth models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Auth: Phantom wallet connection
  phantomWalletHash    String?   @unique  // SHA-256(phantom_wallet_address)

  // Blockchain: assigned AGNTC coin coordinate (one per user, unique on-chain)
  blockchainTokenX     Int?              // assigned grid coordinate X
  blockchainTokenY     Int?              // assigned grid coordinate Y

  // Subscription
  subscription         SubscriptionTier?  // null until plan chosen

  // Game starting conditions (cached from chain)
  startAgentId  String?
  startEnergy   Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([subscription])
  @@unique([blockchainTokenX, blockchainTokenY])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Waitlist ---

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  ip        String?             // for rate-limiting spam from same IP
  createdAt DateTime @default(now())
}

// --- Subscription tiers ---

enum SubscriptionTier {
  COMMUNITY      // Free — 1,000 CPU Energy, 1 Moore ring
  PROFESSIONAL   // $50/mo — 5,000 CPU Energy, 2 Moore rings
  MAX            // Dormant — 20,000 CPU Energy (hidden from UI)
}
