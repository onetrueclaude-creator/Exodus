{
  "permissions": {
    "allow": [
      "Read(**/seed.md)",
      "Read(**/CLAUDE.md)",
      "Read(.claude/**)",
      "Read(inbox.md)",
      "Read(outbox.md)",

      "Write(**/seed.md)",
      "Write(**/CLAUDE.md)",
      "Write(.claude/journal.md)",
      "Write(.claude/internals/*.md)",
      "Write(.claude/priorities.md)",
      "Write(outbox.md)",

      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(mkdir:*)",
      "Bash(find:*)",
      "Bash(wc:*)",

      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(node:*)",

      "Bash(python3:*)",
      "Bash(pip3:*)",
      "Bash(uvicorn:*)",

      "Bash(docker:*)",
      "Bash(docker compose:*)"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./ .claude/hooks/stop-log.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./ .claude/hooks/precompact.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./ .claude/hooks/session-start-compact.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./ .claude/hooks/user-prompt-log.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
