{
  "permissions": {
    "allow": [
      "Read(**/seed.md)",
      "Read(**/CLAUDE.md)",
      "Write(**/seed.md)",
      "Write(**/CLAUDE.md)",

      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(env:*)",
      "Bash(stat:*)",
      "Bash(lsof:*)",
      "Bash(wc:*)",
      "Bash(find:*)",

      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",

      "Bash(grep:*)",
      "Bash(rg:*)",

      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(jq:*)",

      "Bash(mkdir:*)",
      "Bash(open:*)",
      "Bash(curl:*)",
      "Bash(ps:*)",
      "Bash(launchctl:*)",

      "Bash(git:*)",
      "Bash(gh:*)",

      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(node:*)",

      "Bash(python3:*)",
      "Bash(pip3:*)",
      "Bash(uvicorn:*)",

      "Bash(docker:*)",
      "Bash(docker compose:*)"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "greptile@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./ .claude/hooks/stop-log.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./ .claude/hooks/precompact.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./ .claude/hooks/session-start-compact.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
